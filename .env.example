# ============================================
# CONFIGURAÇÃO SUPABASE - TEMPLATE
# ============================================
# 1. Copie este arquivo para .env na raiz do projeto
# 2. Preencha com suas credenciais do Supabase
# 3. O arquivo .env está no .gitignore e não será versionado

# Supabase URL (encontre em Settings > Database)
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

# Credenciais (encontre em Settings > Database > Connection string)
# Use o formato: [project_id]_[password]@[host]
DB_USER=postgres.[seu_projectid_aqui]
DB_PASSWORD=seu_password_supabase_aqui

# Pool de conexões (Supabase recomenda 5-10)
DB_POOL_SIZE=5

# JWT Secret (use uma chave forte em produção)
JWT_SECRET=sua_chave_jwt_super_segura_aqui

# Perfil ativo (dev, prod, staging)
SPRING_PROFILES_ACTIVE=dev
